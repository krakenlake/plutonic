.PHONY: default release clean

default: this

LIBRV64STRINGS_VERSION = 0.0.1

LIBRV64STRINGS_TARGET ?= qemu-64g
#LIBRV64STRINGS_TARGET ?= vf2

LIBRV64STRINGS_TARGET_XLEN ?= 64

# tools
LIBRV64STRINGS_TOOLBIN	?= /usr/local/bin
LIBRV64STRINGS_CC			?= $(LIBRV64STRINGS_TOOLBIN)/riscv64-elf-gcc
LIBRV64STRINGS_CPP		?= $(LIBRV64STRINGS_TOOLBIN)/riscv64-elf-cpp
LIBRV64STRINGS_AR			?= $(LIBRV64STRINGS_TOOLBIN)/riscv64-elf-ar
LIBRV64STRINGS_RANLIB		?= $(LIBRV64STRINGS_TOOLBIN)/riscv64-elf-ranlib

# CFLAGS
CFLAGS = -march=rv$(LIBRV64STRINGS_TARGET_XLEN)g
CFLAGS += -I"$(LIBRV64STRINGS_SRCD)/include"
CFLAGS += -DDEBUG
CFLAGS += -DPLUTONIC_VERSION=\"$(PLUTONIC_VERSION)\"
# warnings
CFLAGS += -Wall -Werror -Wextra -pedantic
# warn if inline function cannot be substituted
CFLAGS += -Winline
# create position-independent code
CFLAGS += -fPIC
# create position-independent executables
CFLAGS += -fPIE
# gcc must not try to replace anything with built-in stuff
CFLAGS += -fno-builtin
# no crt0
CFLAGS += -nostartfiles
# optimisation
CFLAGS += -O2
# add debug symbols
CFLAGS += -g
LIBRV64STRINGS_CFLAGS ?= $(CFLAGS)

# names
LIBRV64STRINGS_NAME			= librv64strings
LIBRV64STRINGS_CONFIG		?= config
LIBRV64STRINGS_BUILDROOT	?= ../build
LIBRV64STRINGS_BUILD		?= $(LIBRV64STRINGS_BUILDROOT)/$(LIBRV64STRINGS_TARGET)/$(LIBRV64STRINGS_NAME)
LIBRV64STRINGS_BUILDCONF	?= $(LIBRV64STRINGS_BUILD)/$(LIBRV64STRINGS_CONFIG)
LIBRV64STRINGS_RELEASE		?= ../release/$(LIBRV64STRINGS_TARGET)
LIBRV64STRINGS_SRC_S		= $(wildcard ./src/*.S)
LIBRV64STRINGS_SRC_C		= $(wildcard ./src/*.c)
LIBRV64STRINGS_SRC			= $(LIBRV64STRINGS_SRC_S) $(LIBRV64STRINGS_SRC_C)
LIBRV64STRINGS_OBJ_S		= $(LIBRV64STRINGS_SRC_S:./src/%.S=$(LIBRV64STRINGS_BUILD)/%.o)
LIBRV64STRINGS_OBJ_C		= $(LIBRV64STRINGS_SRC_C:./src/%.c=$(LIBRV64STRINGS_BUILD)/%.o)
LIBRV64STRINGS_OBJ			= $(LIBRV64STRINGS_OBJ_S) $(LIBRV64STRINGS_OBJ_C)
LIBRV64STRINGS_DEP			= $(LIBRV64STRINGS_OBJ:%.o=%.d)

# dependencies
-include $(LIBRV64STRINGS_DEP)


# targets
this: Makefile $(LIBRV64STRINGS_BUILD)/$(LIBRV64STRINGS_NAME).a
	@ls -ln $(LIBRV64STRINGS_BUILD)/$(LIBRV64STRINGS_NAME).a

$(LIBRV64STRINGS_BUILD) $(LIBRV64STRINGS_RELEASE):
	mkdir -p $@

$(LIBRV64STRINGS_BUILD)/$(LIBRV64STRINGS_NAME).a: $(LIBRV64STRINGS_BUILD) $(LIBRV64STRINGS_OBJ) Makefile $(LIBRV64STRINGS_BUILD)/config.h
	$(LIBRV64STRINGS_AR) r $@ $(LIBRV64STRINGS_BUILD)/*.o
	$(LIBRV64STRINGS_RANLIB) $@

$(LIBRV64STRINGS_BUILD)/config.h: $(LIBRV64STRINGS_BUILD) $(LIBRV64STRINGS_CONFIG)/config.$(LIBRV64STRINGS_TARGET).h
	cp $(LIBRV64STRINGS_CONFIG)/config.$(LIBRV64STRINGS_TARGET).h $@

$(LIBRV64STRINGS_BUILD)/%.o: ./src/%.S Makefile $(LIBRV64STRINGS_BUILD)/config.h
	$(LIBRV64STRINGS_CC) $(LIBRV64STRINGS_CFLAGS) -I$(LIBRV64STRINGS_BUILD) -Iinclude -MMD -c $< -o $@

$(LIBRV64STRINGS_BUILD)/%.o: ./src/%.c Makefile $(LIBRV64STRINGS_BUILD)/config.h
	$(LIBRV64STRINGS_CC) $(LIBRV64STRINGS_CFLAGS) -I$(LIBRV64STRINGS_BUILD) -Iinclude -MMD -c $< -o $@

$(LIBRV64STRINGS_RELEASE)/$(LIBRV64STRINGS_NAME)-$(LIBRV64STRINGS_TARGET).a: $(LIBRV64STRINGS_BUILD)/$(LIBRV64STRINGS_NAME).a
	cp $< $@
	@ls -ln $@

release: Makefile $(LIBRV64STRINGS_RELEASE) $(LIBRV64STRINGS_RELEASE)/$(LIBRV64STRINGS_NAME)-$(LIBRV64STRINGS_TARGET).a

clean:
	rm -fr $(LIBRV64STRINGS_BUILD)
